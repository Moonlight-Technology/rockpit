generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BoardRole {
  OWNER
  MEMBER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  DONE
}

enum ProjectResourceKind {
  TEXT
  URL
  SECRET
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  avatarUrl    String?
  passwordHash String
  boardsOwned  Board[]      @relation("BoardOwner")
  boardMembers BoardMember[]
  assignedTasks Task[]      @relation("TaskAssignee")
  taskAssignments TaskAssignment[] @relation("TaskAssignmentUser")
  createdTasks Task[]       @relation("TaskCreator")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Board {
  id          String        @id @default(cuid())
  title       String
  description String
  theme       String
  tags        String[]      @default([])
  dueDate     DateTime?
  closedAt    DateTime?
  ownerId     String
  owner       User          @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     BoardMember[]
  columns     BoardColumn[]
  tasks       Task[]
  projectInfo BoardProjectInfo?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model BoardProjectInfo {
  id        String                 @id @default(cuid())
  boardId   String                 @unique
  notes     String?
  board     Board                  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  resources BoardProjectResource[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

model BoardProjectResource {
  id            String              @id @default(cuid())
  projectInfoId String
  title         String              @default("General")
  resourceKey   String              @default("")
  label         String
  value         String
  kind          ProjectResourceKind @default(TEXT)
  position      Int                 @default(0)
  projectInfo   BoardProjectInfo    @relation(fields: [projectInfoId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([projectInfoId, position])
}

model BoardMember {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  role      BoardRole @default(MEMBER)
  isPinned  Boolean   @default(false)
  pinnedAt  DateTime?
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([boardId, userId])
  @@index([userId, isPinned])
}

model BoardColumn {
  id        String   @id @default(cuid())
  boardId   String
  title     String
  position  Int
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId, position])
}

model Task {
  id          String      @id @default(cuid())
  boardId     String?
  columnId    String?
  assigneeId  String?
  createdById String
  title       String
  description String?
  startDate   DateTime?
  dueDate     DateTime?
  plannedStartAt DateTime?
  plannedDurationMinutes Int?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  completedAt DateTime?
  position    Int
  board       Board?      @relation(fields: [boardId], references: [id], onDelete: SetNull)
  column      BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assignees   TaskAssignment[]
  createdBy   User        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([boardId, columnId, position])
  @@index([assigneeId, dueDate])
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("TaskAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, userId])
  @@index([userId, taskId])
}
